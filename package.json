{
  "name": "@eulertour/studio",
  "description": "three.js code to use in Euler Studio",
  "author": "eulertour",
  "license": "ISC",
  "version": "1.0.33",
  "type": "module",
  "main": "./build/bundle.js",
  "typings": "./build/bundle.d.ts",
  "declaration": true,
  "declarationMap": true,
  "scripts": {
    "dev": "concurrently --prefix-colors auto --names server,studio \"npm run dev:server\" \"npm run dev:source\"",
    "dev:server": "npm --prefix server run dev",
    "dev:source": "nodemon -w src -e js,ts --exec 'npm run build:source'",
    "build": "npm run build:source && npm run build:api",
    "build:source": "rollup --config rollup.config.ts --configPlugin typescript --configImportAttributesKey with",
    "build:api": "npm run transpileJs && npm run extractApi && npm run parseJson",
    "transpileJs": "cd docs/tsc && tsc",
    "extractApi": "api-extractor run --config docs/apiExtractor/api-extractor.json --local --verbose",
    "parseJson": "cd docs/parser && tsc ; node index.js ../apiExtractor/studio.api.json ../../build/api.json",
    "test": "mocha",
    "genTypes": "rollup --config rollup.three-types.config.ts --configPlugin typescript",
    "storage-dev": "nodemon -w src -e js,ts --exec 'npm run build && npm run storage-deploy-emulator'",
    "storage-deploy-emulator": "npm --prefix storageDeploy run deploy-emulator"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.3",
    "@eslint/js": "^9.17.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.9",
    "@types/three": "^0.152.0",
    "@types/ws": "^8.5.10",
    "axios": "^1.7.2",
    "chai": "^5.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "express": "^4.21.2",
    "globals": "^15.14.0",
    "http-server": "^14.1.1",
    "mocha": "^10.7.3",
    "nodemon": "^2.0.22",
    "rollup": "^4.29.1",
    "serve": "^14.2.0",
    "tslib": "^2.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.18.2",
    "ws": "^8.17.0"
  },
  "dependencies": {
    "@microsoft/api-extractor": "^7.42.1",
    "colors": "^1.4.0",
    "eslint-config-prettier": "^9.1.0",
    "firebase-admin": "^13.0.1",
    "mathjax-full": "^3.2.2",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "three": "^0.153.0"
  }
}
