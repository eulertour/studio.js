{
  "type": "module",
  "scripts": {
    "dev:scene": "nodemon dist/index.js",
    "build:server": "tsc",
    "build:scene": "tsc --project scene",
    "build:source": "OUTPUT_DIR=preview/previewServer/public/studio npm --prefix .. run build:source",
    "watch:server": "nodemon --watch index.ts --exec 'npm run build:server'",
    "watch:scene": "nodemon --watch scene/scene.ts --exec 'npm run build:scene'",
    "watch:source": "nodemon --watch ../src --ext ts --exec 'npm run build:source'"
  }
}
